{
  "name": "deluge-rpc-socket",
  "version": "1.0.0",
  "description": "Node.js API for Deluge's Binary Socket RPC API",
  "type": "module",
  "main": "dist/DelugeRPC.js",
  "types": "dist/DelugeRPC.d.ts",
  "exports": {
    ".": {
      "types": "./dist/DelugeRPC.d.ts",
      "default": "./dist/DelugeRPC.js"
    }
  },
  "files": [
    "dist/DelugeRPC.js",
    "dist/DelugeRPC.js.map",
    "dist/DelugeRPC.d.ts",
    "dist/DelugeRPC.d.ts.map",
    "dist/utils/AllPromises.js",
    "dist/utils/AllPromises.js.map",
    "dist/utils/AllPromises.d.ts",
    "dist/utils/AllPromises.d.ts.map",
    "dist/utils/Awaitable.js",
    "dist/utils/Awaitable.js.map",
    "dist/utils/Awaitable.d.ts",
    "dist/utils/Awaitable.d.ts.map",
    "dist/utils/SharedPromise.js",
    "dist/utils/SharedPromise.js.map",
    "dist/utils/SharedPromise.d.ts",
    "dist/utils/SharedPromise.d.ts.map"
  ],
  "engines": {
    "bun": ">=1.3",
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc",
    "test": "bun test src",
    "lint": "tsc --noEmit",
    "format": "prettier --write .",
    "prepublishOnly": "bun run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cinderblock/node-deluge-rpc.git"
  },
  "keywords": [
    "deluge",
    "deluge-rpc",
    "rpc",
    "bittorrent",
    "torrent",
    "rencode",
    "python-rencode"
  ],
  "author": "Cameron Tacklind <cameron@tacklind.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/cinderblock/node-deluge-rpc/issues"
  },
  "homepage": "https://github.com/cinderblock/node-deluge-rpc#readme",
  "dependencies": {
    "camelcase-keys-deep": "^0.1.0",
    "pako": "^1.0.10",
    "python-rencode": "^2.0.0",
    "smallest-power-of-two": "^2.0.0",
    "snakecase-keys": "^3.1.0"
  },
  "devDependencies": {
    "@types/bun": "^1.2.0",
    "@types/camelcase-keys-deep": "^0.1.0",
    "@types/node": "^22.19.19",
    "@types/pako": "^1.0.1",
    "prettier": "^3.5.0",
    "typescript": "^6.0.3"
  }
}
